# Copy to .env (never commit .env). Render: set the same keys in the dashboard.

# --- LLM (Groq 기본, 또는 Ollama OpenAI 호환) ---
GROQ_API_KEY=
# Ollama 예: LLM_CHAT_PROVIDER=openai_compat
# OPENAI_COMPAT_BASE_URL=http://localhost:11434/v1
# OPENAI_COMPAT_API_KEY=ollama
# OPENAI_COMPAT_MODEL=gains-coach
# Ollama만 쓸 때 에이전트 비활성: USE_LEGACY_CHAT=1
# 무료/on_demand 티어: 요청 토큰(입력+max 출력) 한도 초과(413 rate_limit_exceeded) 시 아래로 더 줄이거나 Dev Tier 사용
# GROQ_MODEL=llama-3.1-8b-instant
# GROQ_MAX_COMPLETION_TOKENS=512
# COACH_CATALOG_MAX_CHARS=8000
# COACH_CATALOG_UNLIMITED=1
# EXERCISE_CATALOG_MAX_PER_MUSCLE=6
# RAG_SNIPPET_MAX_CHARS=450
# RAG_TOP_K_CORPUS=4
# RAG_TOP_K_USER=2
# COACH_LONG_FIELD_MAX_CHARS=3000

# --- Auth ---
# HS256 anonymous JWT (Flutter /auth/anonymous)
AUTH_JWT_SECRET=
# Optional: Supabase Auth RS256 — set both to accept logged-in users (see services/supabase_jwt.py)
# SUPABASE_JWKS_URL=https://YOUR_PROJECT.supabase.co/auth/v1/.well-known/jwks.json
# SUPABASE_JWT_ISS=https://YOUR_PROJECT.supabase.co/auth/v1
# SUPABASE_JWT_AUD=authenticated

# --- Embeddings (Pinecone 차원 = 임베딩 벡터 길이) ---
# openai: default. Pinecone 인덱스는 text-embedding-3-small 기본 1536차원(또는 OPENAI_EMBEDDING_DIMENSIONS)
# huggingface: 무료 티어 후보 — HF 토큰 + 인덱스를 모델 차원에 맞춤 (예: all-MiniLM-L6-v2 → 384)
EMBEDDING_BACKEND=openai
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_EMBEDDING_DIMENSIONS=1536

HUGGINGFACE_API_TOKEN=
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- RAG / Pinecone ---
RAG_BACKEND=auto
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
PINECONE_NAMESPACE=corpus

# --- User memory API (Pinecone namespaces per subject) ---
MEMORY_API_ENABLED=1

# --- Supabase Postgres (optional) ---
# DATABASE_URL=postgresql://postgres:...@db.xxx.supabase.co:5432/postgres

# --- Rate limits / coach ---
# USE_LEGACY_CHAT=0
